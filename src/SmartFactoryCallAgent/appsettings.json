{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Azure Communication Services settings
  "Acs": {
    "ConnectionString": "<YOUR_ACS_CONNECTION_STRING>",
    "PhoneNumber": "<YOUR_ACS_PHONE_NUMBER>",
    "CallbackBaseUrl": "<YOUR_CONTAINER_APP_URL>"
  },

  // Azure OpenAI Realtime settings
  "OpenAi": {
    "Endpoint": "<YOUR_AZURE_OPENAI_ENDPOINT>",
    "ApiKey": "<YOUR_AZURE_OPENAI_API_KEY>",
    "DeploymentName": "gpt-4o-realtime"
  },

  // Azure AI Foundry settings
  "Foundry": {
    "ProjectEndpoint": "<YOUR_AI_FOUNDRY_PROJECT_ENDPOINT>"
  },

  // Microsoft Fabric Eventhouse (KQL) settings
  "Fabric": {
    "KustoEndpoint": "<YOUR_FABRIC_EVENTHOUSE_KQL_ENDPOINT>",
    "DatabaseName": "<YOUR_KQL_DATABASE_NAME>"
  },

  // Manager on-duty phone number for outbound PSTN call
  "ManagerPhoneNumber": "<MANAGER_PHONE_NUMBER>"
}
