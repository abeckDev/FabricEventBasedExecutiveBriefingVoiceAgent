// ============================================================
// FABRIC EVENTHOUSE COMPLETE SETUP
// Database: FactoryEventhouse
// Run this entire script in your Fabric KQL Queryset
// ============================================================

// ============================================================
// STEP 1: CREATE ALL TABLES
// ============================================================

// Raw events table (landing table for all incoming events)
.create table RawEvents (
    EventType: string,
    MachineId: string,
    StationName: string,
    OrderId: string,
    Payload: dynamic,
    IngestTime: datetime
)

// Machine telemetry table
.create table MachineTelemetry (
    MachineId: string,
    StationName: string,
    OrderId: string,
    Vibration: real,
    Temperature: real,
    Pressure: real,
    Status: string,
    Timestamp: datetime
)

// Assembly events table
.create table AssemblyEvents (
    StationName: string,
    OrderId: string,
    EventType: string,
    Details: string,
    Timestamp: datetime
)

// Production KPIs table
.create table ProductionKPIs (
    StationName: string,
    OEE: real,
    ScrapRate: real,
    Uptime: real,
    UnitsProduced: int,
    Timestamp: datetime
)

// Orders table
.create table Orders (
    OrderId: string,
    ProductName: string,
    Status: string,
    Quantity: int,
    DueDate: datetime,
    StationName: string,
    CreatedAt: datetime
)

// Supply risk table
.create table SupplyRisk (
    Material: string,
    Supplier: string,
    RiskLevel: string,
    RiskDescription: string,
    AssessmentDate: datetime
)

// ============================================================
// STEP 2: ENABLE STREAMING INGESTION
// ============================================================

.alter table RawEvents policy streamingingestion enable

.alter table MachineTelemetry policy streamingingestion enable

.alter table AssemblyEvents policy streamingingestion enable

.alter table ProductionKPIs policy streamingingestion enable

.alter table Orders policy streamingingestion enable

.alter table SupplyRisk policy streamingingestion enable

// ============================================================
// STEP 3: CREATE JSON INGESTION MAPPINGS
// ============================================================

// Mapping for RawEvents
.create table RawEvents ingestion json mapping "RawEventsMapping"
'['
'  {"column":"EventType",  "path":"$.EventType",   "datatype":"string"},'
'  {"column":"MachineId",  "path":"$.MachineId",   "datatype":"string"},'
'  {"column":"StationName","path":"$.StationName",  "datatype":"string"},'
'  {"column":"OrderId",    "path":"$.OrderId",      "datatype":"string"},'
'  {"column":"Payload",    "path":"$",              "datatype":"dynamic"},'
'  {"column":"IngestTime", "path":"$.Timestamp",    "datatype":"datetime"}'
']'

// Mapping for MachineTelemetry
.create table MachineTelemetry ingestion json mapping "MachineTelemetryMapping"
'['
'  {"column":"MachineId",   "path":"$.MachineId",   "datatype":"string"},'
'  {"column":"StationName", "path":"$.StationName", "datatype":"string"},'
'  {"column":"OrderId",     "path":"$.OrderId",     "datatype":"string"},'
'  {"column":"Vibration",   "path":"$.Vibration",   "datatype":"real"},'
'  {"column":"Temperature", "path":"$.Temperature", "datatype":"real"},'
'  {"column":"Pressure",    "path":"$.Pressure",    "datatype":"real"},'
'  {"column":"Status",      "path":"$.Status",      "datatype":"string"},'
'  {"column":"Timestamp",   "path":"$.Timestamp",   "datatype":"datetime"}'
']'

// Mapping for AssemblyEvents
.create table AssemblyEvents ingestion json mapping "AssemblyEventsMapping"
'['
'  {"column":"StationName", "path":"$.StationName",        "datatype":"string"},'
'  {"column":"OrderId",     "path":"$.OrderId",            "datatype":"string"},'
'  {"column":"EventType",   "path":"$.AssemblyEventType",  "datatype":"string"},'
'  {"column":"Details",     "path":"$.Details",            "datatype":"string"},'
'  {"column":"Timestamp",   "path":"$.Timestamp",          "datatype":"datetime"}'
']'

// Mapping for ProductionKPIs
.create table ProductionKPIs ingestion json mapping "ProductionKPIsMapping"
'['
'  {"column":"StationName",    "path":"$.StationName",    "datatype":"string"},'
'  {"column":"OEE",            "path":"$.OEE",            "datatype":"real"},'
'  {"column":"ScrapRate",      "path":"$.ScrapRate",      "datatype":"real"},'
'  {"column":"Uptime",         "path":"$.Uptime",         "datatype":"real"},'
'  {"column":"UnitsProduced",  "path":"$.UnitsProduced",  "datatype":"int"},'
'  {"column":"Timestamp",      "path":"$.Timestamp",      "datatype":"datetime"}'
']'

// ============================================================
// STEP 4: CREATE UPDATE POLICIES (AUTO-ROUTING)
// ============================================================

// Function to extract MachineTelemetry from RawEvents
.create-or-alter function ExtractMachineTelemetry() {
    RawEvents
    | where EventType == "MachineTelemetry"
    | extend
        MachineId   = tostring(Payload.MachineId),
        StationName = tostring(Payload.StationName),
        OrderId     = tostring(Payload.OrderId),
        Vibration   = todouble(Payload.Vibration),
        Temperature = todouble(Payload.Temperature),
        Pressure    = todouble(Payload.Pressure),
        Status      = tostring(Payload.Status),
        Timestamp   = todatetime(Payload.Timestamp)
    | project MachineId, StationName, OrderId, Vibration, Temperature, Pressure, Status, Timestamp
}

// Update policy for MachineTelemetry
.alter table MachineTelemetry policy update
@'[{"IsEnabled": true, "Source": "RawEvents", "Query": "ExtractMachineTelemetry()", "IsTransactional": false, "PropagateIngestionProperties": false}]'

// Function to extract AssemblyEvents from RawEvents
.create-or-alter function ExtractAssemblyEvents() {
    RawEvents
    | where EventType == "AssemblyEvent"
    | extend
        StationName = tostring(Payload.StationName),
        OrderId     = tostring(Payload.OrderId),
        EventType   = tostring(Payload.AssemblyEventType),
        Details     = tostring(Payload.Details),
        Timestamp   = todatetime(Payload.Timestamp)
    | project StationName, OrderId, EventType, Details, Timestamp
}

// Update policy for AssemblyEvents
.alter table AssemblyEvents policy update
@'[{"IsEnabled": true, "Source": "RawEvents", "Query": "ExtractAssemblyEvents()", "IsTransactional": false, "PropagateIngestionProperties": false}]'

// Function to extract ProductionKPIs from RawEvents
.create-or-alter function ExtractProductionKPIs() {
    RawEvents
    | where EventType == "ProductionKPI"
    | extend
        StationName   = tostring(Payload.StationName),
        OEE           = todouble(Payload.OEE),
        ScrapRate     = todouble(Payload.ScrapRate),
        Uptime        = todouble(Payload.Uptime),
        UnitsProduced = toint(Payload.UnitsProduced),
        Timestamp     = todatetime(Payload.Timestamp)
    | project StationName, OEE, ScrapRate, Uptime, UnitsProduced, Timestamp
}

// Update policy for ProductionKPIs
.alter table ProductionKPIs policy update
@'[{"IsEnabled": true, "Source": "RawEvents", "Query": "ExtractProductionKPIs()", "IsTransactional": false, "PropagateIngestionProperties": false}]'

// ============================================================
// STEP 5: SEED INITIAL DATA
// ============================================================

