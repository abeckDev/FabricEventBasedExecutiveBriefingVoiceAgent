// ============================================================
// VERIFICATION QUERIES
// ============================================================

// Verify all tables were created
.show tables

// Check table schemas
.show table RawEvents schema
.show table MachineTelemetry schema

// Verify data seeding
SupplyRisk | count
Orders | count

// Done! Your Eventhouse is ready for the Smart Factory demo.
